{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GovernanceOperations/AIOps/schemas/aiops-config.json",
  "title": "AIOps Configuration Schema",
  "description": "Schema for aiops.yml configuration file per GADS v0.1",
  "type": "object",
  "required": ["govops_version", "aiops", "ledger", "domains"],
  "properties": {
    "govops_version": {
      "type": "string",
      "enum": ["0.9"],
      "description": "GOS version this deployment conforms to"
    },
    "aiops": {
      "type": "object",
      "required": ["deployment_id", "tier"],
      "properties": {
        "deployment_id": { "type": "string", "minLength": 3 },
        "tier": { "type": "integer", "minimum": 1, "maximum": 4 }
      }
    },
    "ledger": {
      "type": "object",
      "required": ["endpoint", "auth_secret", "chain_id", "signature_algorithm"],
      "properties": {
        "endpoint": { "type": "string", "format": "uri" },
        "auth_secret": { "type": "string" },
        "chain_id": { "type": "string" },
        "signature_algorithm": {
          "type": "string",
          "enum": ["dilithium3", "dilithium5", "falcon512", "falcon1024"],
          "description": "Post-quantum algorithm per GOS §11.2"
        },
        "alert_channel": { "type": "string" }
      }
    },
    "gps_endpoint": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "url": { "type": "string", "format": "uri" },
        "auth_secret": { "type": "string" },
        "session_negotiation": { "type": "boolean" }
      }
    },
    "domains": {
      "type": "object",
      "properties": {
        "technical":   { "$ref": "#/definitions/domain_config" },
        "governance":  { "$ref": "#/definitions/domain_config" },
        "financial":   { "$ref": "#/definitions/domain_config" },
        "security":    { "$ref": "#/definitions/domain_config" },
        "identity":    { "$ref": "#/definitions/domain_config" },
        "stakeholder": { "$ref": "#/definitions/domain_config" },
        "adversarial": { "$ref": "#/definitions/domain_config" }
      }
    },
    "analysis": {
      "type": "object",
      "properties": {
        "anomaly_detection": {
          "type": "object",
          "properties": {
            "baseline_window_days": { "type": "integer", "minimum": 7, "maximum": 365 },
            "baseline_recompute_hours": { "type": "integer", "minimum": 1 },
            "tiers": {
              "type": "object",
              "properties": {
                "informational": { "type": "number" },
                "notable": { "type": "number" },
                "significant": { "type": "number" },
                "critical": { "type": "number" }
              }
            },
            "baseline_shift_alert_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "correlation": {
          "type": "object",
          "properties": {
            "check_interval_minutes": { "type": "integer", "minimum": 1 },
            "correlation_window_minutes": { "type": "integer", "minimum": 1 },
            "mandatory_patterns": {
              "type": "object",
              "properties": {
                "security_plus_financial": { "type": "boolean" },
                "identity_plus_governance_bypass": { "type": "boolean" },
                "stakeholder_decline_plus_disclosure_delay": { "type": "boolean" },
                "multi_discipline_alert_spike": { "type": "boolean" },
                "ai_drift_plus_data_quality": { "type": "boolean" },
                "pipeline_bypass_plus_security_decline": { "type": "boolean" }
              }
            }
          }
        },
        "synthetic_detection": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "methods": {
              "type": "object",
              "properties": {
                "statistical_distribution": { "type": "boolean" },
                "temporal_sequence": { "type": "boolean" },
                "cross_source_consistency": { "type": "boolean" },
                "provenance_chain": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "epistemic_field": {
      "type": "object",
      "properties": {
        "confirmed_staleness_class1_days": { "type": "integer", "minimum": 1 },
        "confirmed_staleness_class23_days": { "type": "integer", "minimum": 1 },
        "efcs_alert_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "efcs_critical_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "unknown_region_critical_domain_max_days": { "type": "integer", "minimum": 1 }
      }
    },
    "self_monitoring": {
      "type": "object",
      "properties": {
        "heartbeat_interval_minutes": { "type": "integer", "minimum": 1 },
        "heartbeat_alert_minutes": { "type": "integer", "minimum": 1 },
        "heartbeat_critical_minutes": { "type": "integer", "minimum": 1 },
        "latency_alert_seconds": { "type": "integer", "minimum": 1 },
        "latency_critical_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "coverage_audit": {
      "type": "object",
      "properties": {
        "schedule": { "type": "string", "description": "Cron expression" },
        "minimum_active_domains": { "type": "integer", "minimum": 1, "maximum": 7 },
        "alert_channel": { "type": "string" }
      }
    },
    "gc_measurement": {
      "type": "object",
      "properties": {
        "normal_mode_schedule": { "type": "string" },
        "stress_mode_schedule": { "type": "string" },
        "crisis_mode_schedule": { "type": "string" },
        "graceful_degradation_schedule": { "type": "string" }
      }
    },
    "retention": {
      "type": "object",
      "properties": {
        "security_events_days": { "type": "integer", "minimum": 1 },
        "technical_metrics_days": { "type": "integer", "minimum": 1 },
        "anomaly_records_days": { "type": "integer", "minimum": 1 },
        "standard_telemetry_days": { "type": "integer", "minimum": 1 }
      }
    },
    "runners": {
      "type": "object",
      "properties": {
        "default": { "type": "string" }
      }
    }
  },
  "definitions": {
    "domain_config": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "auth_secret"],
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["prometheus", "webhook", "gps_audit", "datadog", "cloudwatch", "custom"]
              },
              "endpoint": { "type": "string", "format": "uri" },
              "auth_secret": { "type": "string" },
              "scrape_interval_seconds": { "type": "integer", "minimum": 1 },
              "poll_interval_seconds": { "type": "integer", "minimum": 1 },
              "governance_critical": { "type": "boolean" }
            }
          }
        },
        "collection_lag_alert_seconds": { "type": "integer", "minimum": 1 },
        "collection_lag_critical_seconds": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "additionalProperties": false
}
