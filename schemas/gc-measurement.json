{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/GovernanceOperations/AIOps/schemas/gc-measurement.json",
  "title": "AIOps GC Component Measurement",
  "description": "Schema for a GC component measurement output per GADS §6.5 and GMF §7.3",
  "type": "object",
  "required": [
    "measurement_id",
    "measurement_timestamp",
    "governing_entity_id",
    "computation_period",
    "components",
    "confidence_factor",
    "outputs",
    "instrument_references"
  ],
  "properties": {
    "measurement_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 unique identifier for this measurement cycle"
    },
    "measurement_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC when measurement was produced"
    },
    "governing_entity_id": {
      "type": "string",
      "description": "Identifier of the Governing Entity being measured"
    },
    "computation_period": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "format": "date-time" },
        "to": { "type": "string", "format": "date-time" }
      },
      "description": "Time period over which component values were computed"
    },
    "operating_mode_at_measurement": {
      "type": "string",
      "enum": ["normal", "stress", "crisis", "graceful_degradation"],
      "description": "Operating mode in effect during this measurement cycle"
    },
    "components": {
      "type": "object",
      "required": ["F", "CA", "II", "AT"],
      "properties": {
        "F": {
          "type": "object",
          "required": ["score", "instrument_count", "class1_count"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "instrument_count": { "type": "integer", "minimum": 0 },
            "class1_count": { "type": "integer", "minimum": 0 },
            "stale_instruments": { "type": "integer", "minimum": 0 },
            "notes": { "type": "string" }
          },
          "description": "Fidelity component score per GOS §2.2"
        },
        "CA": {
          "type": "object",
          "required": ["score", "instrument_count", "class1_count"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "instrument_count": { "type": "integer", "minimum": 0 },
            "class1_count": { "type": "integer", "minimum": 0 },
            "stale_instruments": { "type": "integer", "minimum": 0 },
            "notes": { "type": "string" }
          },
          "description": "Capacity to Act component score per GOS §2.2"
        },
        "II": {
          "type": "object",
          "required": ["score", "instrument_count", "class1_count"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "instrument_count": { "type": "integer", "minimum": 0 },
            "class1_count": { "type": "integer", "minimum": 0 },
            "stale_instruments": { "type": "integer", "minimum": 0 },
            "notes": { "type": "string" }
          },
          "description": "Institutional Integrity component score per GOS §2.2"
        },
        "AT": {
          "type": "object",
          "required": ["score", "instrument_count", "class1_count"],
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 1 },
            "instrument_count": { "type": "integer", "minimum": 0 },
            "class1_count": { "type": "integer", "minimum": 0 },
            "stale_instruments": { "type": "integer", "minimum": 0 },
            "notes": { "type": "string" }
          },
          "description": "Adaptive Transparency component score per GOS §2.2"
        }
      }
    },
    "confidence_factor": {
      "type": "object",
      "required": ["oas", "mu_factor", "efcs", "composite"],
      "properties": {
        "oas": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Observer Agreement Score per GMF §4.1"
        },
        "mu_factor": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Measurement Uncertainty Factor per GMF §4.2"
        },
        "efcs": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Epistemic Field Coverage Score per GMF §4.3"
        },
        "composite": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Composite Confidence Factor = OAS × MU_factor × EFCS per GMF §4.4"
        }
      }
    },
    "outputs": {
      "type": "object",
      "required": ["raw_gc", "effective_gc", "operational_state_assessed"],
      "properties": {
        "raw_gc": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Raw GC = F × CA × II × AT per GOS §2.2"
        },
        "effective_gc": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "Effective GC = Raw GC × Confidence Factor per GOS §26.5"
        },
        "operational_state_assessed": {
          "type": "integer", "minimum": 0, "maximum": 4,
          "description": "Governance Operational State (0-4) per GOS §26.6"
        }
      }
    },
    "instrument_references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["instrument_id", "component", "class", "value", "staleness_status"],
        "properties": {
          "instrument_id": { "type": "string" },
          "component": { "type": "string", "enum": ["F", "CA", "II", "AT"] },
          "class": { "type": "string", "enum": ["1", "2", "3"] },
          "value": { "type": "number", "minimum": 0, "maximum": 1 },
          "last_updated": { "type": "string", "format": "date-time" },
          "staleness_status": { "type": "string", "enum": ["current", "stale", "expired"] }
        }
      },
      "description": "All GMF instruments contributing to this measurement, per MIR entries"
    },
    "gps_evaluate_message_ref": {
      "type": "string",
      "description": "GPS evaluate message_id written to Immutable Ledger for this measurement"
    }
  },
  "additionalProperties": false
}
